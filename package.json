{
    "name": "tailwind-hitslop",
    "version": "0.1.2",
    "description": "Hit-slop utilities for Tailwind CSS v4 (and v3 via plugin) — invisible expanded touch targets, like React Native's hitSlop.",
    "license": "MIT",
    "author": "İlker Balcılar",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Jubstaaa/tailwind-hitslop.git"
    },
    "homepage": "https://tailwind-hitslop.vercel.app",
    "bugs": "https://github.com/Jubstaaa/tailwind-hitslop/issues",
    "style": "./dist/index.css",
    "types": "./dist/plugin.d.ts",
    "exports": {
        ".": {
            "types": "./dist/plugin.d.ts",
            "style": "./dist/index.css",
            "require": "./dist/plugin.js",
            "import": "./dist/plugin.js",
            "default": "./dist/index.css"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsc -p tsconfig.build.json && cp index.css dist/",
        "test": "vitest run"
    },
    "peerDependencies": {
        "tailwindcss": "^3.0.0 || ^4.0.0"
    },
    "peerDependenciesMeta": {
        "tailwindcss": {
            "optional": true
        }
    },
    "keywords": [
        "tailwindcss",
        "tailwind",
        "hit-slop",
        "hitslop",
        "touch-target",
        "tap-target",
        "a11y",
        "css"
    ],
    "devDependencies": {
        "@tailwindcss/node": "^4.3.0",
        "@types/node": "^24.0.0",
        "postcss": "^8.5.0",
        "tailwindcss-v3": "npm:tailwindcss@3.0.0",
        "typescript": "^6.0.3",
        "vitest": "^4.1.8"
    }
}
